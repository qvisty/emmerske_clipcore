---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Kontakt">

  <section class="bg-brand-50 py-16 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-4xl font-bold text-brand-800 mb-4">Kontakt os</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Vi hoerer gerne fra dig. Ring, skriv eller kom paa besog.</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <div>
          <h2 class="text-2xl font-bold text-brand-800 mb-8">Send os en besked</h2>
          <form id="contactForm" class="space-y-6" method="POST" action="https://formspree.io/f/mkgwwqpo">
            <div id="successMessage" class="hidden bg-green-100 border-2 border-green-400 text-green-700 px-5 py-4 rounded-xl">
              Tak for din besked! Vi vender tilbage snarest.
            </div>
            <div id="errorMessage" class="hidden bg-red-100 border-2 border-red-400 text-red-700 px-5 py-4 rounded-xl">
              Der skete en fejl. Proev igen eller ring os direkte paa 74 72 44 33.
            </div>
            <div>
              <label class="block text-base font-semibold text-gray-700 mb-2" for="navn">Navn</label>
              <input type="text" id="navn" name="navn" placeholder="Dit fulde navn" required
                class="w-full px-5 py-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:border-brand-500 transition-colors" />
            </div>
            <div>
              <label class="block text-base font-semibold text-gray-700 mb-2" for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="din@email.dk" required
                class="w-full px-5 py-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:border-brand-500 transition-colors" />
            </div>
            <div>
              <label class="block text-base font-semibold text-gray-700 mb-2" for="telefon">Telefon (valgfri)</label>
              <input type="tel" id="telefon" name="telefon" placeholder="Dit telefonnummer"
                class="w-full px-5 py-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:border-brand-500 transition-colors" />
            </div>
            <div>
              <label class="block text-base font-semibold text-gray-700 mb-2" for="besked">Besked</label>
              <textarea id="besked" name="besked" rows="5" placeholder="Skriv din besked her..." required
                class="w-full px-5 py-4 text-lg border-2 border-gray-200 rounded-xl focus:outline-none focus:border-brand-500 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full py-4 bg-brand-600 hover:bg-brand-700 text-white text-xl font-semibold rounded-xl transition-colors">
              Send besked
            </button>
          </form>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-brand-800 mb-8">Find os</h2>
          <div class="bg-gray-100 rounded-2xl overflow-hidden mb-8 border-2 border-gray-200">
            <iframe
              title="Emmerske Efterskole paa kortet"
              width="100%"
              height="350"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2289.9!2d8.867!3d54.939!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sAabenraavej+14%2C+6270+T%C3%B8nder!5e0!3m2!1sda!2sdk!4v1234567890">
            </iframe>
          </div>
          <div class="space-y-4">
            <div class="flex items-start gap-4 bg-white rounded-2xl p-5 border-2 border-brand-100">
              <div class="text-3xl flex-shrink-0">&#x1F4CD;</div>
              <div>
                <p class="font-semibold text-brand-800 text-lg">Adresse</p>
                <p class="text-gray-600">Aabenraavej 14, 6270 Toender</p>
              </div>
            </div>
            <div class="flex items-start gap-4 bg-white rounded-2xl p-5 border-2 border-brand-100">
              <div class="text-3xl flex-shrink-0">&#x1F4DE;</div>
              <div>
                <p class="font-semibold text-brand-800 text-lg">Telefon</p>
                <a href="tel:74724433" class="text-brand-600 hover:text-brand-800 text-lg font-semibold transition-colors">74 72 44 33</a>
              </div>
            </div>
            <div class="flex items-start gap-4 bg-white rounded-2xl p-5 border-2 border-brand-100">
              <div class="text-3xl flex-shrink-0">&#x1F4E7;</div>
              <div>
                <p class="font-semibold text-brand-800 text-lg">Email</p>
                <a href="mailto:ee@eeskole.dk" class="text-brand-600 hover:text-brand-800 text-lg font-semibold transition-colors">ee@eeskole.dk</a>
              </div>
            </div>
          </div>
          <div class="mt-8 bg-brand-600 rounded-2xl p-8 text-center text-white">
            <div class="text-4xl mb-3">&#x1F3E0;</div>
            <h3 class="text-xl font-bold mb-2">Book en rundvisning</h3>
            <p class="text-brand-100 mb-4">Kom og se skolen med egne oeyne. Vi gloeder os til at vise dig rundt!</p>
            <a href="tel:74724433" class="inline-block px-8 py-3 bg-white text-brand-700 font-semibold rounded-xl hover:bg-brand-50 transition-colors">Ring: 74 72 44 33</a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contactForm');
  const successMsg = document.getElementById('successMessage');
  const errorMsg = document.getElementById('errorMessage');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Hide messages
      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok || response.status === 302) {
          // Show success message
          successMsg?.classList.remove('hidden');
          form.reset();
          window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
        } else {
          // If Formspree fails, fall back to mailto
          fallbackToMailto();
        }
      } catch (error) {
        console.error('Form submission error:', error);
        fallbackToMailto();
      }
    });

    function fallbackToMailto() {
      const navn = document.getElementById('navn').value || 'Navn ikke angivet';
      const email = document.getElementById('email').value || 'Email ikke angivet';
      const telefon = document.getElementById('telefon').value || 'Ej angivet';
      const besked = document.getElementById('besked').value || 'Besked ikke angivet';

      const body = `Navn: ${navn}\nEmail: ${email}\nTelefon: ${telefon}\n\nBesked:\n${besked}`;
      const mailtoLink = `mailto:ee@eeskole.dk?subject=Ny%20besked%20fra%20kontaktformular&body=${encodeURIComponent(body)}`;

      window.location.href = mailtoLink;
    }
  }
</script>