---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityToolbar from '../components/AccessibilityToolbar.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Emmerske Efterskole - Din skole med hjertet paa rette sted',
  ogImage = 'https://qvisty.github.io/emmerske_clipcore/og-image.jpg',
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, 'https://qvisty.github.io').href;
const pageTitle = `${title} | Emmerske Efterskole`;
---
<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href={base + 'favicon.svg'} />
  <!-- OpenDyslexic font til ordblinde-venlig tilstand -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <style>
    @font-face {
      font-family: 'OpenDyslexic';
      src: url('https://cdn.jsdelivr.net/npm/opendyslexic@latest/fonts/OpenDyslexic-Regular.otf') format('opentype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
  </style>
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="da_DK" />
  <meta property="og:site_name" content="Emmerske Efterskole" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
</head>
<body class="font-sans text-gray-900 bg-white antialiased">

  <!-- Spring til indhold (tilgaengelighed) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand-700 focus:text-white focus:rounded-lg focus:text-base focus:font-semibold">
    Spring til indhold
  </a>

  <Header />
  <AccessibilityToolbar />
  <main id="main-content" class="min-h-screen">
    <slot />
  </main>
  <Footer />

</body>
</html>
<style is:global>
  html { font-size: 18px; scroll-behavior: smooth; }
  body { line-height: 1.75; letter-spacing: 0.01em; }

  /* Synlige fokusindikatorer for alle interaktive elementer */
  :focus-visible {
    outline: 3px solid #0369a1;
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Ordblinde-venlig skrift tilstand */
  html.dyslexic-mode,
  html.dyslexic-mode body,
  html.dyslexic-mode p,
  html.dyslexic-mode h1,
  html.dyslexic-mode h2,
  html.dyslexic-mode h3,
  html.dyslexic-mode h4,
  html.dyslexic-mode li,
  html.dyslexic-mode a,
  html.dyslexic-mode span,
  html.dyslexic-mode div {
    font-family: 'OpenDyslexic', Arial, sans-serif !important;
    letter-spacing: 0.05em !important;
    word-spacing: 0.15em !important;
    line-height: 2 !important;
  }

  /* Hoej kontrast tilstand */
  html.high-contrast,
  html.high-contrast body {
    background-color: #000 !important;
    color: #fff !important;
  }
  html.high-contrast .bg-white,
  html.high-contrast .bg-brand-50,
  html.high-contrast .bg-brand-100 {
    background-color: #111 !important;
  }
  html.high-contrast h1,
  html.high-contrast h2,
  html.high-contrast h3,
  html.high-contrast .text-brand-800,
  html.high-contrast .text-brand-700 {
    color: #ffe066 !important;
  }
  html.high-contrast p,
  html.high-contrast .text-gray-600,
  html.high-contrast .text-gray-700,
  html.high-contrast .text-gray-500 {
    color: #e0e0e0 !important;
  }
  html.high-contrast a.bg-brand-600,
  html.high-contrast button.bg-brand-600,
  html.high-contrast .bg-brand-600 {
    background-color: #ffe066 !important;
    color: #000 !important;
  }
  html.high-contrast .border-brand-100,
  html.high-contrast .border-brand-200 {
    border-color: #555 !important;
  }

  /* Video responsiv wrapper */
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 1rem;
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
